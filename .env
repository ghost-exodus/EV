# POSTGRES_PASSWORD=ev_password
# POSTGRES_DB=ev_telemetry
# DATABASE_URL=postgresql://ev_user:ev_password@postgres:5432/ev_telemetry

# # --- Weeks 5 & 6 Configuration ---
# # NEVER commit real secrets. Use environment injection in production.
# INTERNAL_API_KEY=<replace-with-secret>

# # SQS configuration (points to local ElasticMQ by default)
# SQS_ENDPOINT_URL=http://elasticmq:9324
# SQS_QUEUE_URL=http://elasticmq:9324/000000000000/ev-telemetry.fifo
# SQS_DLQ_URL=http://elasticmq:9324/000000000000/ev-telemetry-dlq.fifo
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=mock_key
# AWS_SECRET_ACCESS_KEY=mock_secret
# CREATE_QUEUES_ON_STARTUP=true

# # Rate limiting — 100/minute per user (Week 7 roadmap requirement)
# # Override to 100000/minute in dev .env to effectively disable during testing
# RATE_LIMIT_RULE=100/minute


POSTGRES_USER=ev_user
POSTGRES_PASSWORD=ev_password
POSTGRES_DB=ev_telemetry

# --- Local Native SQLite Override (Bypasses Docker Postgres) ---
DATABASE_URL=sqlite:///./ev_telemetry.db

# --- Security & Auth ---
INTERNAL_API_KEY=super_secret_internal_api_key_123

# --- SQS Mock Bypass for Local Native Run ---
SQS_ENDPOINT_URL=
SQS_QUEUE_URL=
SQS_DLQ_URL=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock_key
AWS_SECRET_ACCESS_KEY=mock_secret
CREATE_QUEUES_ON_STARTUP=false

# --- Rate limiting Override for Testing ---
RATE_LIMIT_RULE=100000/minute